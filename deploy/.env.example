# ClawDeploy v3 Environment Configuration

# PostgreSQL Database
POSTGRES_USER=clawdeploy

# Generate password: openssl rand -base64 32 | tr -d "=+/" | cut -c1-32
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_SECURE_PASSWORD

POSTGRES_DB=clawdeploy

# Update this with the same password as POSTGRES_PASSWORD above
DATABASE_URL=postgresql://clawdeploy:CHANGE_ME_GENERATE_SECURE_PASSWORD@postgres:5432/clawdeploy

# Dashboard Authentication (Nginx Basic Auth)
BETA_USER=openclaw

# Generate password: openssl rand -base64 32 | tr -d "=+/" | cut -c1-32
BETA_PASSWORD=en8juc5J0HmM4wC6GWHX89hn5T0e5aOE

# Domain or IP
DOMAIN=beta.friendlabs.ai

# Dashboard API URL (for frontend build-time config)
VITE_API_URL=/api

# OpenClaw Version (for building agent images)
OPENCLAW_VERSION=latest

# Agent Bridge Configuration (Optional - for local agent)
AGENT_NAME=Local OpenClaw Agent
AGENT_DESCRIPTION=OpenClaw agent with full skill suite
OPENCLAW_GATEWAY_URL=ws://host.docker.internal:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_MODE=gateway
OPENCLAW_SKILLS_PATH=/openclaw/skills
HEARTBEAT_INTERVAL_MS=30000
COMMAND_POLL_INTERVAL_MS=5000
LOG_LEVEL=info

# LLM Configuration (for agents - not used on control plane)
# Using GLM from ZhipuAI
# Get your API key from: https://open.bigmodel.cn/
# Valid models: glm-4, glm-4-flash, glm-4.7-flash (recommended, newest)
ZHIPU_API_KEY=
OPENCLAW_MODEL=glm-4.7-flash
