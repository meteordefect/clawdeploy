# ClawDeploy Custom - copy to .env and fill
# (Ansible copies this to the VPS)
DOMAIN=46.225.118.34

# Same as main clawdeploy – use same .env or copy POSTGRES_* from main
POSTGRES_USER=clawdeploy
POSTGRES_PASSWORD=changeme
POSTGRES_DB=clawdeploy

# Deploy/rollback access (optional)
# DEPLOY_ALLOW_NO_REFERER=1   Allow curl/OpenClaw deploy when no Referer (default: require /dashboard/custom)
# ALLOW_DEPLOY_FROM_MAIN=1    Let main dashboard trigger deploy (default: custom only)
# ROLLBACK_RESTRICT_TO_CUSTOM=1  Restrict rollback to custom dashboard only (default: main can rollback)

# API URLs (used at build time for dashboard)
VITE_API_URL=/dashboard/custom/api
# Gateway WebSocket URL - set explicitly, or Ansible derives from DOMAIN (ws for IP, wss for domain)
VITE_GATEWAY_WS_URL=wss://your-domain.com/gateway/ws
VITE_GATEWAY_TOKEN=
VITE_BASE_PATH=/dashboard/custom/
